export LANG=en_US.UTF-8

[[ -z "$TMUX" && $- == *i* ]] && exec tmux new-session -A -s main
export PATH="$HOME/.local/bin:$PATH"
export EDITOR=nvim
export VISUAL=nvim
# set the directory for zinit and plugins
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
export JDTLS_JAVA_EXECUTABLE="/usr/lib/jvm/java-21-openjdk/bin/java"

# Download Zinit, if its not there
if [ ! -d "$ZINIT_HOME" ]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# source
source "${ZINIT_HOME}/zinit.zsh"

# plugins
zinit light zsh-users/zsh-completions
zinit light Aloxaf/fzf-tab

zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# add in snippets
zinit snippet OMZP::alias-finder
zinit snippet OMZP::git
zinit snippet OMZP::sudo
zinit snippet OMZP::command-not-found

# Load completions
autoload -Uz compinit && compinit -d ~/.cache/zcompdump-$ZSH_VERSION

zinit cdreplay -q

export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=244'
export ZSH_AUTOSUGGEST_STRATEGY=(history completion)
# command bar
eval "$(starship init zsh)"

# Keybindings
bindkey -e
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward


# History
HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

# completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'

# alises
alias ls='eza --color=always --icons'
alias ll='eza --color=always -lha --icons --git'
alias lt='eza --color=always --tree --level=2 --icons'

alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -I'

alias cleanup='sudo xbps-remove -Oo'

alias glog='git log --oneline --graph --decorate --all' 

alias nzsh='nvim ~/.zshrc'
alias szsh='source ~/.zshrc'
alias n='nvim'

# shell integrations
eval "$(fzf --zsh)"

setopt nobeep
export XBPS_DISTDIR="$HOME/.void-packages"

if [ -z "$XDG_RUNTIME_DIR" ]; then
    export XDG_RUNTIME_DIR=/run/user/$(id -u)
fi

eval "$(zoxide init --cmd cd zsh)"
